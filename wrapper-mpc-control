
#!/bin/bash

if [ -f $HOME/.dmenurc ]; then
  . $HOME/.dmenurc
else
  DMENU='dmenu -i -l 20'
fi


# Define the options
options=("Artist" "Composer" "Track" "Next" "Playlist" "Jump" "Longplayer" "Genre")

# Prompt the user to select a mode using dmenu
selected_mode=$(printf "%s\n" "${options[@]}" | $DMENU -p "Select Mode:")

# Check the selected mode and call your script accordingly
case $selected_mode in
    "Artist")
        mpc_control -a
        ;;
    "Composer")
        mpc_control -c
        ;;
    "Track")
        mpc_control -t
        ;;
    "Next")
        mpc_control -n
        ;;
    "Playlist")
        mpc_control -p
        ;;
    "Jump")
        mpc_control -j
        ;;
    "Longplayer")
        mpc_control -l
        ;;
    "Genre")
         mpc_control -g
        ;;
    *)
        echo "Invalid mode selected."
        ;;
esac
